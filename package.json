{
  "name": "dawn-of-empires",
  "version": "1.0.0",
  "description": "Dawn of Empires",
  "author": "Pierre Nicolas <tenzin50@hotmail.fr",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierre50/RTS-game.git"
  },
  "scripts": {
    "clean": "rimraf build",
    "dev": "webpack serve --mode development",
    "start": "pnpm dev",
    "build": "pnpm clean && webpack --mode production",
    "build:dev": "pnpm clean && webpack --mode development",
    "dist": "pnpm build && electron-builder",
    "compile": "pnpm dist",
    "deploy": "pnpm build && gh-pages -d build",
    "format": "prettier --write \"app/**/*.{js,css}\" \"*.{js,json}\"",
    "precommit": "lint-staged",
    "lint": "eslint ./app/**/*.js"
  },
  "build": {
    "appId": "com.pierre50.dawn-of-empires",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "your.app.category.type"
    },
    "asar": true,
    "files": [
      "main.js",
      {
        "from": "build",
        "to": "build",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@pixi/sound": "^6.0.1",
    "pixi-filters": "^6.1.5",
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.4",
    "electron": "^42.0.0",
    "electron-builder": "^26.14.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "file-loader": "^6.2.0",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.6.2",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.4"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.8",
      "serialize-javascript": ">=7.0.3",
      "uuid": ">=11.1.1",
      "electron-builder-squirrel-windows": "26.14.0"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "plugins": [
    "prettier"
  ],
  "lint-staged": {
    "*.{js,json}": [
      "prettier --write --single-quote",
      "git add"
    ]
  }
}
